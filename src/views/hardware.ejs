<%- include('./partials/head.ejs') %>
<link rel='stylesheet' href='/stylesheets/style.css' />
<link rel='stylesheet' href='/stylesheets/hardware.css' />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<body>
  <!-- Fondo oscuro de respaldo para el Drawer -->
  <div id="drawer-overlay" class="drawer-overlay"></div>

  <div class="container">
    <div class="contenedor-acciones-flex cabecera-hardware">
        <h1><%= title %></h1>
        <div style="display: flex; gap: 10px;">
            <!-- BOTÓN QUE DISPARA EL DRAWER DE ALTA -->
            <button type="button" id="btn-abrir-alta" class="btn-ux btn-ux-nuevo" style="padding: 10px 15px;">
                ➕ Registrar Componente
            </button>
            <a href="/" class="btn-ux btn-ux-editar" style="padding: 10px 15px;">⬅️ Volver al Inicio</a>
        </div>
    </div>

    <!-- Buscador de Repuestos -->
    <form action="/hardware" method="GET" class="form-busqueda">
        <input type="text" name="q" placeholder="🔍 Buscar por nombre de componente..." class="input-busqueda" value="<%= busqueda %>">
        <button type="submit" class="btn-buscar">Buscar</button>
        <a href="/hardware" class="btn-link-cancelar">Limpiar</a>
    </form>

    <div class="contenedor-hardware">
        
        <!-- DRAWER LATERAL DERECHO (FORMULARIO OCULTO) -->
        <div class="bloque-formulario hardware-drawer" id="hardware-drawer">
            <div class="drawer-header">
                <h3><%= hardwareEditar ? '📝 Modificar Componente' : '➕ Agregar Componente' %></h3>
                <button type="button" class="btn-cerrar-drawer" id="btn-cerrar-drawer">✕</button>
            </div>
            
            <form action="/hardware/<%= hardwareEditar ? 'editar/' + hardwareEditar.id_hardware : 'guardar' %>" 
                  method="POST" 
                  enctype="multipart/form-data" 
                  class="form-hardware">
                
                <label>Nombre del Componente:</label>
                <input type="text" name="componente" placeholder="Ej: Memoria RAM Kingston 8GB DDR4" required value="<%= hardwareEditar ? hardwareEditar.componente : '' %>">
                
                <label>Categoría:</label>
                <select name="categoria" required>
                    <option value="Memorias RAM" <%= hardwareEditar && hardwareEditar.categoria === 'Memorias RAM' ? 'selected' : '' %>>Memorias RAM</option>
                    <option value="Discos Rígidos (HDD)" <%= hardwareEditar && hardwareEditar.categoria === 'Discos Rígidos (HDD)' ? 'selected' : '' %>>Discos Rígidos (HDD)</option>
                    <option value="Discos Sólidos (SSD/NVMe)" <%= hardwareEditar && hardwareEditar.categoria === 'Discos Sólidos (SSD/NVMe)' ? 'selected' : '' %>>Discos Sólidos (SSD/NVMe)</option>
                    <option value="Combos de Actualización" <%= hardwareEditar && hardwareEditar.categoria === 'Combos de Actualización' ? 'selected' : '' %>>Combos de Actualización</option>
                    <option value="Placas de Video" <%= hardwareEditar && hardwareEditar.categoria === 'Placas de Video' ? 'selected' : '' %>>Placas de Video</option>
                    <option value="Fuentes de Alimentación" <%= hardwareEditar && hardwareEditar.categoria === 'Fuentes de Alimentación' ? 'selected' : '' %>>Fuentes de Alimentación</option>
                    <option value="Pantallas de Notebook" <%= hardwareEditar && hardwareEditar.categoria === 'Pantallas de Notebook' ? 'selected' : '' %>>Pantallas de Notebook</option>
                </select>

                <label>Precio de Costo ($):</label>
                <input type="number" step="0.01" name="precio_costo" required value="<%= hardwareEditar ? hardwareEditar.precio_costo : '0.00' %>">

                <label>Precio de Venta al Público ($):</label>
                <input type="number" step="0.01" name="precio_venta" required value="<%= hardwareEditar ? hardwareEditar.precio_venta : '0.00' %>">

                <label>Stock Inicial (Unidades):</label>
                <input type="number" name="stock" required value="<%= hardwareEditar ? hardwareEditar.stock : '0' %>">

                <% if (hardwareEditar && hardwareEditar.imagen) { %>
                    <div class="contenedor-vista-previa-edicion">
                        <small class="txt-foto-actual">Foto actual:</small>
                        <img src="/images/hardware/<%= hardwareEditar.imagen %>" alt="Actual" class="img-vista-previa-edicion">
                    </div>
                <% } %>

                <label for="imagen-repuesto" class="label-subida-imagen">Foto del Componente (Opcional):</label>
                <input type="file" name="imagen" id="imagen-repuesto" accept="image/png, image/jpeg, image/jpg, image/webp" class="input-file-hardware">

                <button type="submit" class="btn-guardar-completo btn-registrar-hardware">
                    <%= hardwareEditar ? 'Guardar Cambios' : 'Registrar Componente' %>
                </button>
                
                <% if(hardwareEditar) { %>
                    <a href="/hardware" class="btn-ux btn-ux-editar btn-cancelar-edicion-hw">Cancelar Edición</a>
                <% } %>
            </form>
        </div>

        <!-- COLUMNA DERECHA COMPLETA: TABLA DE INVENTARIO -->
        <div class="bloque-tabla">
            <h3>Inventario en Taller</h3>
            <table class="tabla-hardware">
                <thead>
                    <tr>
                        <th class="columna-imagen-th">Imagen</th>
                        <th>Categoría</th>
                        <th>Componente</th>
                        <th>Costo</th>
                        <th>PVP (Venta)</th>
                        <th>Stock</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(listaHardware.length > 0) { %>
                        <% listaHardware.forEach(item => { %>
                            <tr>
                                <td class="celda-imagen-td">
                                    <img src="/images/hardware/<%= item.imagen || 'default-hardware.png' %>" alt="<%= item.componente %>" class="img-miniatura-tabla">
                                </td>
                                <td><small class="badge-estado-inicio"><%= item.categoria %></small></td>
                                <td><strong><%= item.componente %></strong></td>
                                <td>$<%= Number(item.precio_costo).toFixed(2) %></td>
                                <td style="color:#2b6cb0; font-weight:bold;">$<%= Number(item.precio_venta).toFixed(2) %></td>
                                <td>
                                    <span class="<%= item.stock <= 2 ? 'stock-alerta' : '' %>">
                                        <%= item.stock %> un.
                                    </span>
                                </td>
                                <td>
                                    <div class="contenedor-acciones-tabla">
                                        <a href="/hardware/editar/<%= item.id_hardware %>" class="btn-ux btn-ux-editar btn-accion-tabla">✏️</a>
                                        <button type="button" class="btn-eliminar-flex btn-accion-tabla" onclick="eliminarComponente('<%= item.id_hardware %>')">🗑️</button>
                                        <form id="form-eliminar-hw-<%= item.id_hardware %>" action="/hardware/eliminar/<%= item.id_hardware %>" method="POST" style="display:none;"></form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" class="celda-sin-registros">No hay componentes registrados en esta categoría.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
  </div>

  <!-- CONTROL DE COMPORTAMIENTO INTERACTIVO DEL DRAWER -->
 <script>
    document.addEventListener('DOMContentLoaded', () => {
      const drawer = document.getElementById('hardware-drawer');
      const overlay = document.getElementById('drawer-overlay');
      const btnAbrirAlta = document.getElementById('btn-abrir-alta');
      const btnCerrar = document.getElementById('btn-cerrar-drawer');

      // Evaluamos desde el servidor si la pantalla cargó en modo Edición o modo Alta estándar
      const estaEditando = <%= hardwareEditar ? 'true' : 'false' %>;

      // Función unificada para abrir el panel lateral
      const abrirDrawer = () => {
         drawer.classList.add('open');
         overlay.classList.add('open');
      };

      // Función unificada para cerrar o abortar la acción actual
      const cerrarDrawer = () => {
         // SI ESTÁ EDITANDO: Al cerrar el panel o tocar el fondo, limpia la URL y restablece el título "Catálogo..."
         if (estaEditando) {
             window.location.href = '/hardware';
         } else {
             // SI ES UN ALTA COMÚN: Solo esconde el panel de forma visual sin recargar la página
             drawer.classList.remove('open');
             overlay.classList.remove('open');
         }
      };

      // Escuchadores de eventos para clicks en la interfaz
      if(btnAbrirAlta) btnAbrirAlta.addEventListener('click', abrirDrawer);
      if(btnCerrar) btnCerrar.addEventListener('click', cerrarDrawer);
      if(overlay) overlay.addEventListener('click', cerrarDrawer);

      // CRÍTICO UX: Si el controlador mandó datos para editar, abrimos el Drawer automáticamente al cargar
      if (estaEditando) {
         abrirDrawer();
      }
    });

    function eliminarComponente(id) {
        Swal.fire({
            title: '¿Eliminar componente?',
            text: "Se quitará este artículo del catálogo de repuestos de forma permanente.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Sí, borrar',
            cancelButtonText: 'Cancelar'
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('form-eliminar-hw-' + id).submit();
            }
        });
    }
  </script>
</body>
</html>