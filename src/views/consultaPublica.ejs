<%- include('./partials/head.ejs') %>
<!-- Vinculamos las hojas de estilo externas -->

<body>
    <div class="container-details container-detalle">
        <h1 class="titulo-consulta"><%= title %></h1>

        <!-- CONTENEDOR DEL FORMULARIO DE CONSULTA -->
        <div class="ficha-beneficiario ficha-consulta-verde">
            <h3 class="subtitulo-card">
                🔍 Seguimiento de Reparación
            </h3>
            <p class="texto-descripcion">
                Ingresá el número de ticket que te entregó el técnico al registrar tu equipo para conocer el estado actual.
            </p>
            
            <form action="/consulta" method="POST" class="form-estado form-consulta">
                <label for="codigo" class="label-consulta">
                    Número de Ticket:
                </label>
                
                <input type="text" name="codigo" id="codigo" class="input-ticket" placeholder="Ej: TICKET-W8F4B2" required>
                
                <button type="submit" class="btn-guardar btn-buscar-ticket">
                    Buscar Orden
                </button>
            </form>
        </div>

        <!-- CONTROL DE ALERTAS DE ERROR -->
        <% if (error) { %>
            <div class="estado-cuenta cuenta-pendiente alertas-error">
                ⚠️ <%= error %>
            </div>
        <% } %>

        <!-- FICHA TÉCNICA EN PANTALLA -->
        <% if (cliente) { %>
            <div class="ficha-beneficiario ficha-resultado-azul">
                <h2 class="titulo-ticket-resultado">Ticket N°: <span class="ticket-destacado"><%= cliente.codigo_seguimiento %></span></h2>
                
                <div class="contenedor-estado-orden">
                    <span class="txt-estado-orden">Estado de la Orden:</span>
                    <span class="badge-estado">
                        <%= cliente.estado %>
                    </span>
                </div>
                
                <hr class="separador-resultado">
                
                <p class="ficha-campo"><strong>Titular:</strong> <%= cliente.nombre %></p>
                <p class="ficha-campo"><strong>Dispositivo:</strong> <%= cliente.equipo %></p>
                <p class="ficha-campo"><strong>Inconveniente Reportado:</strong> <%= cliente.falla %></p>
                
                <!-- Sección de cuentas de solo lectura para el cliente -->
                <div id="seccion-presupuesto" class="seccion-presupuesto seccion-presupuesto-publica">
                    <p class="ficha-campo"><strong>Costo Total del Servicio:</strong> $<%= Number(cliente.presupuesto).toFixed(2) %></p>
                    <p class="ficha-campo"><strong>Seña / Adelanto Entregado:</strong> $<%= Number(cliente.pago_parcial).toFixed(2) %></p>
                    
                    <% let deuda = Number(cliente.presupuesto) - Number(cliente.pago_parcial); %>
                    <div class="estado-cuenta <%= deuda <= 0 ? 'cuenta-saldada' : 'cuenta-pendiente' %> alerta-deuda-publica">
                        <% if (deuda <= 0) { %>
                            <span>✅ El servicio se encuentra completamente abonado. ¡Muchas gracias!</span>
                        <% } else { %>
                            <span>⚠️ Saldo pendiente a abonar al retirar: <strong>$<%= deuda.toFixed(2) %></strong></span>
                        <% } %>
                    </div>
                    
                    <p class="ficha-campo texto-aprobacion">
                        <strong>Aprobación técnica:</strong> 
                        <%= cliente.confirmado ? 'Presupuesto aprobado por el cliente. ✅' : 'Esperando confirmación del presupuesto. ⏳' %>
                    </p>
                </div>
            </div>
        <% } %>
        
        <!-- ENLACE DE REDIRECCIÓN AL PANEL TÉCNICO -->
        <div class="container-redireccion-tecnico">
            <a href="/users/login" class="link-personal-tecnico">
                Acceso Exclusivo Personal Técnico →
            </a>
        </div>
    </div>
</body>
</html>
