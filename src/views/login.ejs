<%- include('./partials/head.ejs') %>
<!-- Vinculamos las hojas de estilo externas -->


<body>
    <div class="container-detalle">
        <h1 class="login-titulo"><%= title %></h1>

        <!-- CONTENEDOR DE IDENTIFICACIÓN -->
        <div class="ficha-beneficiario">
            <h3 class="login-subtitulo">
                🔐 Panel de Identificación Técnico
            </h3>
            
            <!-- Estructura mandatoria para el login conectado a la base de datos -->
                <form action="/users/login" method="POST">
    
                 <!-- CASILLERO DE USUARIO (Debe tener name="username") -->
                     <label for="username">Nombre de Usuario:</label>
                    <input type="text" name="username" id="username" placeholder="Ingresá tu usuario" required>

                    <!-- CASILLERO DE CONTRASEÑA (Debe tener name="password") -->
                    <label for="password">Contraseña:</label>
                    <input type="password" name="password" id="password" placeholder="Ingresá tu contraseña" required>

                    <button type="submit">Ingresar al Taller</button>
                </form>

        </div>

        <!-- CONTROL DE ALERTAS DE ERROR -->
        <% if (error) { %>
            <div class="estado-cuenta cuenta-pendiente login-error">
                ❌ <%= error %>
            </div>
        <% } %>

        <!-- ENLACE DE RETORNO PÚBLICO -->
        <div class="login-retorno-container">
            <a href="/consulta" class="login-link-retorno">
                ← Volver a Consulta de Reparaciones (Clientes)
            </a>
        </div>
    </div>
</body>
</html>
