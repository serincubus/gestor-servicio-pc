<%- include('./partials/head.ejs') %>

<div class="container-historial">
    <h1>Historial de Reparaciones y Pagos</h1>
    <a href="/" class="btn-volver-panel">← Volver al Panel Principal</a>

    <!-- MÓDULO ESTADÍSTICO MENSUAL CONTROLADO POR CLASES CSS -->
    <div class="contenedor-estadisticas">
        <h2>📊 Resumen de Caja Mensual</h2>
        
        <% if (Object.keys(estadisticas).length > 0) { %>
            <div class="grilla-meses">
                <% for (let mes in estadisticas) { %>
                    <div class="tarjeta-mes">
                        <h3><%= mes %></h3>
                        
                        <div class="fila-monto-total">
                            <span>Monto Mensual:</span>
                            <strong>$<%= estadisticas[mes].montoTotalMensual.toFixed(2) %></strong>
                        </div>

                        <div class="fila-estadistica">
                            <span>Total Cobrado:</span>
                            <strong class="txt-cobrado">$<%= estadisticas[mes].cobrado.toFixed(2) %></strong>
                        </div>
                        
                        <div class="fila-estadistica">
                            <span>Por Recaudar:</span>
                            <strong class="txt-pendiente">$<%= estadisticas[mes].pendiente.toFixed(2) %></strong>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } else { %>
            <p style="color: #718096; font-style: italic;">No hay datos financieros suficientes para generar el reporte mensual.</p>
        <% } %>
    </div>

    <!-- TABLA GRÁFICA DETALLADA -->
    <h2 style="margin-top: 40px; color: #333;">📋 Detalle de Movimientos</h2>
    <table class="tabla-grafica">
        <thead>
            <tr>
                <th>Fecha Ingreso</th>
                <th>Cliente</th>
                <th>Equipo</th>
                <th>Descripción Falla</th>
                <th>Fecha Egreso</th>
                <th>Estado de Cuentas</th>
            </tr>
        </thead>
        <tbody>
            <% if (lista.length > 0) { %>
                <% lista.forEach(cliente => { %>
                    <tr>
                        <td>
                            <%= new Date(cliente.createdAt).toLocaleDateString('es-AR') %>
                        </td>
                        <td class="td-cliente"><%= cliente.nombre %></td>
                        <td><%= cliente.equipo %></td>
                        <td class="td-falla" title="<%= cliente.falla %>"><%= cliente.falla %></td>
                        <td>
                            <%= cliente.fecha_egreso ? new Date(cliente.fecha_egreso).toLocaleDateString('es-AR') : 'Pendiente ⏳' %>
                        </td>
                        <td class="td-pago">
                            <small style="color: #666; display: block; margin-bottom: 2px;">Total: $<%= Number(cliente.presupuesto).toFixed(2) %></small>
                            <span class="txt-cobrado" style="display: block; font-weight: bold;">
                                Cobrado: $<%= Number(cliente.pago_parcial || 0).toFixed(2) %>
                            </span>
                            
                            <% let restante = Number(cliente.presupuesto) - Number(cliente.pago_parcial || 0); %>
                            <% if (restante > 0) { %>
                                <span class="txt-pendiente" style="display: block; font-size: 13px; font-weight: bold; margin-top: 4px;">
                                    Resta: $<%= restante.toFixed(2) %> ⏳
                                </span>
                            <% } else { %>
                                <span class="txt-cobrado" style="display: block; font-size: 12px; font-weight: bold; margin-top: 4px;">
                                    Saldado ✅
                                </span>
                            <% } %>

                            <span class="info-confirmacion">
                                <%= cliente.confirmado ? 'Presupuesto Aprobado 👍' : 'Sin Confirmar 👎' %>
                            </span>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="6" style="text-align: center; color: #999; padding: 30px;">
                        No hay registros en el historial todavía.
                    </td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>
</body>
</html>
