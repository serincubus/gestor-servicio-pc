<%- include('./partials/head.ejs') %>
<!-- Vinculamos la hoja de estilos externa limpia -->
<link rel='stylesheet' href='/stylesheets/detalleCliente.css' />
<!-- Importación robusta de SweetAlert2 -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container-details container-detalle">

    <p class="badge-codigo-seguimiento">
        🎫 Código de Seguimiento: <%= cliente.codigo_seguimiento %>
    </p>
    
    <div class="ficha-beneficiario">
        <h2>Ficha de Ingreso #<%= cliente.id_cliente %></h2>
        <p class="ficha-campo"><strong>Beneficiario / Cliente:</strong> <%= cliente.nombre %></p>
        <p class="ficha-campo">
            <strong>Teléfono de Contacto:</strong> <%= cliente.telefono ? cliente.telefono : 'No registrado' %>
            <% if (cliente.telefono) { %>
                <% 
                    let telefonoLimpio = cliente.telefono.replace(/[^0-9]/g, '');
                    if (!telefonoLimpio.startsWith('54')) {
                        telefonoLimpio = '549' + telefonoLimpio;
                    }
                    let mensajeWhatsApp = `Hola ${cliente.nombre}, te avisamos del servicio técnico que tu equipo (${cliente.equipo}) ya ingresó en reparación en nuestro taller. Podés realizar el seguimiento en tiempo real con tu Número de Ticket: ${cliente.codigo_seguimiento} ingresando acá: http://localhost:3000/consulta`;
                    let mensajeCodificado = encodeURIComponent(mensajeWhatsApp);
                %>
                <a href="https://wa.me<%= telefonoLimpio %>?text=<%= mensajeCodificado %>" target="_blank" rel="noopener noreferrer" class="btn-whatsapp" title="Notificar ingreso al cliente por WhatsApp">
                    💬 Enviar Ticket por WhatsApp
                </a>
            <% } %>
        </p>

        <p class="ficha-campo"><strong>Equipo a Reparar:</strong> <%= cliente.equipo %></p>
        <p class="ficha-campo"><strong>Falla Reportada:</strong> <%= cliente.falla %></p>
        <p class="ficha-campo"><small>Registrado el: <%= new Date(cliente.createdAt).toLocaleDateString('es-AR') %></small></p>
    </div>

    <!-- Formulario en detalleCliente.ejs -->
    <form action="/actualizar-estado/<%= cliente.id_cliente %>" method="POST">
        <label for="select-estado">Estado actual:</label>
        <select name="estado" id="select-estado">
            <option value="Ingresado" <%= cliente.estado == 'Ingresado' ? 'selected' : '' %>>Ingresado</option>
            <option value="En Revisión" <%= cliente.estado == 'En Revisión' ? 'selected' : '' %>>En Revisión</option>
            <option value="En Reparación" <%= cliente.estado == 'En Reparación' ? 'selected' : '' %>>En Reparación</option>
            <option value="Listo" <%= cliente.estado == 'Listo' ? 'selected' : '' %>>Listo</option>
        </select>

        <!-- SECCIÓN DE PRESUPUESTO CONTROLADA POR CLASES CSS -->
        <div id="seccion-presupuesto" class="seccion-presupuesto">
            <!-- SELECTOR MULTINIVEL DE HARDWARE: CATEGORÍAS PRIMERO -->
            <div class="componente-hardware-seccion-ux">
                <label>🛠️ Presupuestar Hardware del Catálogo:</label>
                <!-- Botón Disparador Principal del Menú -->
                <button type="button" id="btn-disparador-hardware" class="btn-ux-disparador">
                    <span id="txt-disparador-actual">🔍 Elegir por Categoría...</span>
                    <span>▼</span>
                </button>

                <!-- Persiana Desplegable Centralizada -->
                <div id="dropdown-lista-hardware" class="dropdown-hardware-persiana">
                    <% if (typeof listaHardware !== 'undefined' && listaHardware.length > 0) { %>
                        <% 
                            let gruposHardware = {};
                            listaHardware.forEach(prod => {
                                if (!gruposHardware[prod.categoria]) {
                                    gruposHardware[prod.categoria] = [];
                                }
                                gruposHardware[prod.categoria].push(prod);
                            });
                        %>

                        <!-- VISTA 1: LISTADO DE CATEGORÍAS (Se ve primero) -->
                        <div id="panel-categorias-raiz">
                            <% 
                                let numCat = 0;
                                for (let nombreCat in gruposHardware) { 
                                    numCat++;
                            %>
                                <div class="item-categoria-click" onclick="mostrarSubmenuComponentes('panel-cat-<%= numCat %>')">
                                    <span>📦 <%= nombreCat %></span>
                                    <span class="badge-conteo-articulos"><%= gruposHardware[nombreCat].length %> artículos ➡️</span>
                                </div>
                            <% } %>
                        </div>

                        <!-- VISTA 2: SUBMENÚS DE COMPONENTES POR CATEGORÍA -->
                        <% 
                            let numPanel = 0;
                            for (let nombreCat in gruposHardware) { 
                                numPanel++;
                        %>
                            <div id="panel-cat-<%= numPanel %>" class="panel-componentes-oculto">
                                <!-- Botón superior para volver al menú de categorías -->
                                <div onclick="regresarAlMenuCategorias()" class="btn-volver-categorias">
                                    ⬅️ Volver a Categorías
                                </div>
                                <% gruposHardware[nombreCat].forEach(prod => { %>
                                    <div class="fila-componente-disponible">
                                        <div class="txt-componente-info">
                                            <strong><%= prod.componente %></strong>
                                            <small>Disponibles: <%= prod.stock %> un.</small>
                                        </div>
                                        <div class="wrapper-precio-carga">
                                            <span class="txt-precio-venta-hardware">$<%= Number(prod.precio_venta).toFixed(2) %></span>
                                            <button type="button" 
                                                    class="btn-cargar-hardware-presupuesto" 
                                                    data-precio="<%= prod.precio_venta %>"
                                                    data-nombre="<%= prod.componente %>"
                                                    style="background-color: #3182ce; color: white; padding: 6px 12px; font-size: 12px; border-radius: 4px; white-space: nowrap; border:none; cursor:pointer; font-weight: bold;"
                                                    onclick="sumarAlPresupuestoDirecto(this)">
                                                ➕ Cargar
                                            </button>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>
                    <% } else { %>
                        <div class="txt-catalogo-vacio">No hay repuestos registrados en el catálogo.</div>
                    <% } %>
                </div>
            </div>
<!-- CONTENEDOR DE ITEMS CARGADOS CON INPUT OCULTO SINCRONIZADO -->
<div id="contenedor-items-cargados">
    <!-- Las tarjetas se inyectarán de forma dinámica aquí -->
</div>
<!-- ➕ NUEVO INPUT OCULTO: Viaja hacia el backend con la estructura de texto serializada -->
<input type="hidden" name="componentes_array_json" id="input-componentes-json" value="[]">


                        <!-- ➕ NUEVA SECCIÓN: LISTA DINÁMICA DE REPUESTOS SELECCIONADOS -->
            <div id="contenedor-items-cargados" style="margin-bottom: 20px; display: flex; flex-direction: column; gap: 10px;">
                <!-- Las tarjetas de hardware elegido se inyectarán aquí mediante JavaScript -->
            </div>

            <!-- Tus casilleros de Presupuesto Total y Adelanto permanecen abajo -->
           
            <label><strong>Presupuesto Total ($):</strong></label>
            <input type="number" name="presupuesto" id="input-presupuesto" value="<%= cliente.presupuesto %>" step="0.01">
            
            <label><strong>Pago Parcial / Adelanto ($):</strong></label>
            <input type="number" name="pago_parcial" value="<%= cliente.pago_parcial %>" step="0.01">

            <!-- CÁLCULO VISUAL DE DEUDA UTILIZANDO CLASES DEL CSS -->
            <% let pendiente = Number(cliente.presupuesto) - Number(cliente.pago_parcial); %>
            <div class="estado-cuenta <%= pendiente <= 0 ? 'cuenta-saldada' : 'cuenta-pendiente' %>">
                <% if (pendiente <= 0) { %>
                    <span>✅ <strong>¡Equipo totalmente saldado!</strong> No registra deuda.</span>
                <% } else { %>
                    <span>⚠️ <strong>Pago Pendiente:</strong> Le resta abonar <strong>$<%= pendiente.toFixed(2) %></strong></span>
                <% } %>
            </div>
            
            <label class="label-confirmado-checkbox">
                <input type="checkbox" name="confirmado" value="true" <%= cliente.confirmado ? 'checked' : '' %>> ¿Cliente confirmó el trabajo?
            </label>
        </div>

                <!-- CONTENEDOR DE BOTONES DE ACCIÓN CON VISIBILIDAD INTELIGENTE -->
        <div class="botones-container">
            <button type="submit" class="btn-guardar">Guardar Cambios</button>
            
            <!-- EL REMITO SOLO SE RENDERIZA SI EL ESTADO ES "LISTO" Y EL PRESUPUESTO ESTÁ CONFIRMADO -->
            <% if (cliente.estado === 'Listo' && (cliente.confirmado === true || cliente.confirmado === 'true')) { %>
                <button type="button" class="btn-remito-print" onclick="imprimirRemitoTaller()">
                    🖨️ Imprimir Remito
                </button>
            <% } %>
            
            <a href="/" class="btn-link-cancelar">Volver al Inicio</a>
        </div>


    </form>
</div>

<script>
    // 1. Oculta el listado principal y abre la lista de hardware de la categoría elegida
    function mostrarSubmenuComponentes(idPanelCategoria) {
        document.getElementById('panel-categorias-raiz').style.display = 'none';
        const todosLosPaneles = document.querySelectorAll('.panel-componentes-oculto');
        todosLosPaneles.forEach(p => p.style.display = 'none');
        const panelDestino = document.getElementById(idPanelCategoria);
        if (panelDestino) {
            panelDestino.style.display = 'block';
        }
    }

    // 2. Vuelve a mostrar las categorías iniciales y esconde el submenú de componentes
    function regresarAlMenuCategorias() {
        document.getElementById('panel-categorias-raiz').style.display = 'block';
        const todosLosPaneles = document.querySelectorAll('.panel-componentes-oculto');
        todosLosPaneles.forEach(p => p.style.display = 'none');
    }

    // 3. Sincroniza la memoria del array con el input oculto del formulario en formato texto
    function actualizarInputOculto() {
        const inputJson = document.getElementById('input-componentes-json');
        if (inputJson) {
            inputJson.value = JSON.stringify(carritoRepuestos);
        }
    }

    // 4. Dibuja una tarjeta visual en la pantalla y le asocia sus funciones de eliminación
    function renderizarTarjetaEnPantalla(idItemUnico, nombre, precio) {
        const contenedorItems = document.getElementById('contenedor-items-cargados');
        if (!contenedorItems) return;

        const tarjetaHardware = document.createElement('div');
        tarjetaHardware.id = idItemUnico;
        tarjetaHardware.className = 'tarjeta-item-agregado';
        
        tarjetaHardware.innerHTML = `
            <div>
                ⚙️ <strong>${nombre}</strong>
            </div>
            <div class="wrapper-precio-carga">
                <span class="txt-precio-venta-hardware">$${precio.toFixed(2)}</span>
                <button type="button" class="btn-quitar-item" onclick="removerHardwareDelPresupuesto('${idItemUnico}', ${precio})">
                    ❌ Quitar
                </button>
            </div>
        `;
        contenedorItems.appendChild(tarjetaHardware);
    }

    // 5. Al presionar el botón ➕ Cargar del selector
    function sumarAlPresupuestoDirecto(elementoBoton) {
        const inputPresupuesto = document.getElementById('input-presupuesto');
        if (inputPresupuesto && elementoBoton) {
            const precioRepuesto = parseFloat(elementoBoton.getAttribute('data-precio')) || 0;
            const nombreComponente = elementoBoton.getAttribute('data-nombre') || 'Componente de Catálogo';
            const presupuestoActual = parseFloat(inputPresupuesto.value) || 0;
            
            inputPresupuesto.value = (presupuestoActual + precioRepuesto).toFixed(2);
            
            const idItemUnico = 'item-hw-' + Date.now() + Math.floor(Math.random() * 100);
            const nuevoItem = { id: idItemUnico, nombre: nombreComponente, precio: precioRepuesto };
            
            carritoRepuestos.push(nuevoItem);
            actualizarInputOculto();
            renderizarTarjetaEnPantalla(idItemUnico, nombreComponente, precioRepuesto);
            
            Swal.fire({
                title: '¡Repuesto Añadido!',
                text: `Se agregó ${nombreComponente} al presupuesto.`,
                icon: 'success',
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 2200
            });
        }
    }

    // 6. Al presionar el botón ❌ Quitar de una tarjeta
    function removerHardwareDelPresupuesto(idTarjeta, precioARestar) {
        const tarjeta = document.getElementById(idTarjeta);
        const inputPresupuesto = document.getElementById('input-presupuesto');
        
        if (tarjeta && inputPresupuesto) {
            const presupuestoActual = parseFloat(inputPresupuesto.value) || 0;
            let nuevoTotal = presupuestoActual - parseFloat(precioARestar);
            if (nuevoTotal < 0) nuevoTotal = 0;
            inputPresupuesto.value = nuevoTotal.toFixed(2);
            
            carritoRepuestos = carritoRepuestos.filter(item => item.id !== idTarjeta);
            actualizarInputOculto();
            
            tarjeta.classList.add('fade-out');
            setTimeout(() => { tarjeta.remove(); }, 200);
            
            Swal.fire({
                title: 'Repuesto Quitado',
                text: 'El valor se descontó del presupuesto total.',
                icon: 'info',
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 2000
            });
        }
    }

    // ➕ CORRECCIÓN CRÍTICA: AGREGAMOS NUEVAMENTE LA FUNCIÓN DE IMPRESIÓN QUE SE HABÍA PERDIDO
    function imprimirRemitoTaller() {
        window.print();
    }

    // Array global que actúa como memoria intermedia del "carrito" en el navegador
    let carritoRepuestos = [];

    // Inicialización de eventos dinámicos al cargar el documento
    document.addEventListener('DOMContentLoaded', () => {
        const btnDisparador = document.getElementById('btn-disparador-hardware');
        const dropdownLista = document.getElementById('dropdown-lista-hardware');

        if (btnDisparador && dropdownLista) {
            btnDisparador.addEventListener('click', (e) => {
                e.stopPropagation();
                if (dropdownLista.style.display === 'none' || dropdownLista.style.display === '') {
                    dropdownLista.style.display = 'block';
                    regresarAlMenuCategorias();
                } else {
                    dropdownLista.style.display = 'none';
                }
            });
            dropdownLista.addEventListener('click', (e) => { e.stopPropagation(); });
            document.addEventListener('click', () => { dropdownLista.style.display = 'none'; });
        }

        // RECONSTRUCCIÓN DEL CARRITO: Leemos los repuestos fijos que inyecta el backend
        <% if (typeof componentesGuardados !== 'undefined' && componentesGuardados.length > 0) { %>
            carritoRepuestos = <%- JSON.stringify(componentesGuardados) %>;
            actualizarInputOculto();
            carritoRepuestos.forEach(item => {
                renderizarTarjetaEnPantalla(item.id, item.nombre, item.precio);
            });
        <% } %>

        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('actualizado') === 'true') {
            Swal.fire({
                title: '¡Cambios Guardados!',
                text: 'La ficha del cliente se actualizó con éxito.',
                icon: 'success',
                confirmButtonColor: '#3085d6',
                confirmButtonText: 'Genial'
            }).then(() => {
                window.history.replaceState({}, document.title, window.location.pathname);
            });
        }
    });
</script>
</body>
</html>
