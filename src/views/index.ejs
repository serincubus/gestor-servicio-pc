<%- include('./partials/head.ejs') %>
<!-- Vinculamos las hojas de estilos externas -->
<link rel='stylesheet' href='/stylesheets/style.css' />
<link rel='stylesheet' href='/stylesheets/formCliente.css' />
<script src="https://jsdelivr.net"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<body>
  <div class="container">
    <h1><%= title %></h1>

    <!-- SECCIÓN DE ACCIONES: BOTONES DE CONTROL SUPERIORES -->
    <div class="acciones-principales">
        <button id="btn-toggle-registro">
            ➕ Registrar Nuevo Ingreso
        </button>
        
        <a href="/history" class="btn-navegar-historial">
            📊 Ver Historial y Reporte de Pagos
        </a>

         <!-- NUEVO BOTÓN: Acceso al inventario de componentes hardware -->
       <a href="/hardware" class="btn-navegar-historial" style="background-color: #6b46c1;">
        💾 Catálogo y Stock de Hardware
       </a>

    </div>

    <!-- CONTENEDOR DESPLEGABLE DEL FORMULARIO DE INGRESO -->
    <div id="contenedor-formulario-registro" class="contenedor-desplegable-registro">
        <h3>Registrar Ingreso de Equipo</h3>
        <form action="/guardar" method="POST" id="form-registro-principal">
          <input type="text" name="nombre" id="input-nombre" placeholder="Nombre del Cliente" required>
          <input type="text" name="telefono" id="input-telefono" placeholder="Teléfono del Cliente" required>
          <input type="text" name="equipo" id="input-equipo" placeholder="Equipo (Ej: Notebook Bangho)" required>
          <textarea name="falla" id="input-falla" placeholder="Descripción del problema"></textarea>
          <button type="submit" class="btn-guardar-completo">Guardar en Base de Datos</button>
        </form>
    </div>

    <hr class="separador-seccion">

    <!-- BARRA DE BÚSQUEDA INTEGRADA -->
    <form action="/search" method="GET" class="form-busqueda">
        <input type="text" name="q" placeholder="🔍 Buscar cliente por nombre..." class="input-busqueda" required>
        <button type="submit" class="btn-buscar">Buscar</button>
        <a href="/" class="btn-link-cancelar">Limpiar</a>
    </form>

    <!-- LISTADO GENERAL DE TARJETAS DE REPARACIÓN -->
    <h2>Equipos en el Taller</h2>
    <div id="lista-reparaciones">
      <% if (lista.length > 0) { %>
        <% lista.forEach(cliente => { %>
          <div class="reparacion-card">
            <strong class="txt-cliente"><%= cliente.nombre %></strong> - <span class="txt-equipo"><%= cliente.equipo %></span>
            <p class="txt-falla">Falla: <%= cliente.falla %></p>
            
           <!-- CONTENEDOR CONTROLLER FLEXBOX PRINCIPAL -->
<div class="contenedor-acciones-flex">
    
    <!-- Grupo Izquierdo: Operaciones de Gestión -->
    <div class="grupo-operaciones-izquierda">
        <a href="/detalle/<%= cliente.id_cliente %>" class="btn-ux btn-ux-detalle">
            🔍 Ver Detalle
        </a>
        <a href="/editar/<%= cliente.id_cliente %>" class="btn-ux btn-ux-editar">
            ✏️ Editar
        </a>
        <button type="button" class="btn-ux btn-ux-nuevo" onclick="prepararNuevoTicket('<%= cliente.cliente.nombre || cliente.nombre %>', '<%= cliente.cliente.telefono || cliente.telefono %>')">
            ➕ Nuevo Ticket
        </button>
    </div>

    <!-- Grupo Derecho: Seguridad / Eliminación -->
    <div class="grupo-seguridad-derecha">
        <button type="button" class="btn-eliminar-flex" onclick="confirmarEliminacion('<%= cliente.id_ticket || cliente.id_cliente %>')">
            🗑️ Eliminar Ticket
        </button>
        <!-- FORMULARIO OCULTO PARA EL POST REAL -->
        <form id="form-eliminar-<%= cliente.id_ticket || cliente.id_cliente %>" action="/eliminar/<%= cliente.id_ticket || cliente.id_cliente %>" method="POST" style="display: none;"></form>
    </div>
    
</div>


            <!-- FORMULARIO OCULTO PARA EL POST REAL -->
            <form id="form-eliminar-<%= cliente.id_ticket || cliente.id_cliente %>" action="/eliminar/<%= cliente.id_ticket || cliente.id_cliente %>" method="POST" style="display: none;"></form>

            <div class="contenedor-estado">
                <small class="badge-estado-inicio">Estado: <%= cliente.estado %></small>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <p class="txt-sin-registros">No hay equipos registrados todavía.</p>
      <% } %>
    </div>
  </div>

  <!-- CONTROL DE INTERFAZ Y COMPORTAMIENTO SCRIPT -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const btnToggle = document.getElementById('btn-toggle-registro');
      const formulario = document.getElementById('contenedor-formulario-registro');

      btnToggle.addEventListener('click', () => {
        if (formulario.style.display === 'none' || formulario.style.display === '') {
          formulario.style.display = 'block';
          btnToggle.textContent = '❌ Cerrar Formulario';
          btnToggle.style.backgroundColor = '#dc3545';
        } else {
          formulario.style.display = 'none';
          btnToggle.textContent = '➕ Registrar Nuevo Ingreso';
          btnToggle.style.backgroundColor = '#007bff';
        }
      });
    });

    function prepararNuevoTicket(nombre, telefono) {
      const btnToggle = document.getElementById('btn-toggle-registro');
      const formulario = document.getElementById('contenedor-formulario-registro');

      if (formulario.style.display === 'none' || formulario.style.display === '') {
        formulario.style.display = 'block';
        btnToggle.textContent = '❌ Cerrar Formulario';
        btnToggle.style.backgroundColor = '#dc3545';
      }

      document.getElementById('input-nombre').value = nombre;
      document.getElementById('input-telefono').value = telefono;
      
      document.getElementById('input-equipo').value = '';
      document.getElementById('input-falla').value = '';
      
      document.getElementById('input-equipo').focus();

      const formPrincipal = document.getElementById('form-registro-principal');
      formPrincipal.style.backgroundColor = '#e6fffa';
      formPrincipal.style.transition = 'background-color 0.4s';
      setTimeout(() => { formPrincipal.style.backgroundColor = 'transparent'; }, 1200);
    }

    function confirmarEliminacion(idTicket) {
      console.log("Intentando eliminar el ticket ID:", idTicket);

      Swal.fire({
          title: '¿Estás completamente seguro?',
          text: "Esta acción borrará el ticket técnico de forma permanente de la base de datos.",
          icon: 'warning',
          showCancelButton: true,
          confirmButtonColor: '#d33',
          cancelButtonColor: '#3085d6',
          confirmButtonText: 'Sí, borrar ticket',
          cancelButtonText: 'Cancelar'
      }).then((result) => {
          if (result.isConfirmed) {
              const formulario = document.getElementById('form-eliminar-' + idTicket);
              if (formulario) {
                  formulario.submit();
              } else {
                  console.error("No se encontró el formulario oculto para el ID:", idTicket);
              }
          }
      });
    }
  </script>
</body>
</html>
